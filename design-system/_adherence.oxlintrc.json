{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/clinical/**",
              "components/core/**",
              "ui_kits/comando-uti/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, size, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|block|as|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, block, as, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|number|action|gravity|padded|interactive|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, eyebrow, number, action, gravity, padded, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='GravityBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|size|label|dot|key|ref|className|style|children)$/]",
        "message": "<GravityBadge> doesn't accept that prop. Declared props: level, size, label, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='GravityBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<GravityBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|icon|multiline|invalid|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, icon, multiline, invalid."
      },
      {
        "selector": "JSXOpeningElement[name.name='LeitoProblem'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|vetor|key|ref|className|style|children)$/]",
        "message": "<LeitoProblem> doesn't accept that prop. Declared props: text, vetor."
      },
      {
        "selector": "JSXOpeningElement[name.name='LeitoProblem'] > JSXAttribute[name.name='vetor'] > Literal[value!=/^(?:↑|↓|=)$/]",
        "message": "<LeitoProblem> vetor must be one of '↑' | '↓' | '='."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProblemRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|vetor|system|hero|eyebrow|key|ref|className|style|children)$/]",
        "message": "<ProblemRow> doesn't accept that prop. Declared props: text, vetor, system, hero, eyebrow."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|hint|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='SofaBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|delta|showIcon|key|ref|className|style|children)$/]",
        "message": "<SofaBadge> doesn't accept that prop. Declared props: score, delta, showIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|tone|icon|delta|active|onClick|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: value, label, tone, icon, delta, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='SystemPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:system|rows|data|title|key|ref|className|style|children)$/]",
        "message": "<SystemPanel> doesn't accept that prop. Declared props: system, rows, data, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='TherapyBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|count|label|showIcon|pulse|key|ref|className|style|children)$/]",
        "message": "<TherapyBadge> doesn't accept that prop. Declared props: type, count, label, showIcon, pulse."
      },
      {
        "selector": "JSXOpeningElement[name.name='VitalStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|status|key|ref|className|style|children)$/]",
        "message": "<VitalStat> doesn't accept that prop. Declared props: label, value, unit, status."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
