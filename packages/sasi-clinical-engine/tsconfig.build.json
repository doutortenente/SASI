{
  // ==========================================================================
  // Build de produção — emite dist/ (JS + .d.ts), exclui testes.
  // Uso: npm run build  ->  tsc -p tsconfig.build.json
  // ==========================================================================
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**"
  ]
}
