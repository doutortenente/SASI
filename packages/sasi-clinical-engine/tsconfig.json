{
  // ==========================================================================
  // SASI Clinical Engine — tsconfig completo (strict)
  // Motor usa imports RELATIVOS (../types, ../calculations/parseBR, ...).
  // O alias "@/*" é conveniência opcional; o vitest.config.ts o espelha.
  // ==========================================================================
  "compilerOptions": {
    // --- Target / módulo (Vite + Vitest, ESM puro) ---
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals", "node"],

    // --- Rigor (freio ABS clínico) ---
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    // "noUncheckedIndexedAccess": true,  // ligar quando o motor estiver 100% coberto por testes
    // "exactOptionalPropertyTypes": true, // idem — agressivo, pode exigir refactor

    // --- Interop / resolução ---
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": false,

    // --- Paths (alias opcional → src/lib) ---
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    // --- Emissão (declarações + sourcemaps; build real fica no tsconfig.build.json) ---
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
