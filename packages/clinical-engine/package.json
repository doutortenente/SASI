{
  "name": "sasi-clinical-engine",
  "version": "1.0.0",
  "description": "Motor clínico SASI — SOFA, qSOFA, Sepsis-3, motor de alertas e cálculos de UTI. TypeScript puro, ZERO dependências de runtime.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scores": {
      "types": "./dist/scores/index.d.ts",
      "import": "./dist/scores/index.js"
    },
    "./alerts": {
      "types": "./dist/alerts/index.d.ts",
      "import": "./dist/alerts/index.js"
    },
    "./calculations": {
      "types": "./dist/calculations/index.d.ts",
      "import": "./dist/calculations/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage",
    "clean": "rm -rf dist",
    "ci": "npm run typecheck && npm run test"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@types/node": "^22.10.0"
  },
  "engines": {
    "node": ">=20"
  }
}
